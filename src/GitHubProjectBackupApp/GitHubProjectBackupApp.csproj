<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>..\..\assets\github-project-backup-icon.ico</ApplicationIcon>
    <AssemblyName>GitHubProjectBackup</AssemblyName>
    <Product>GitHub Project Backup</Product>
    <Description>Scan external drives and back up projects to private GitHub repositories.</Description>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="..\..\Backup-GitHubProjects.ps1">
      <Link>Backup-GitHubProjects.ps1</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\assets\github-project-backup-icon.ico">
      <Link>github-project-backup-icon.ico</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
